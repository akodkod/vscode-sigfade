{
  "name": "sigfade",
  "displayName": "Sigfade",
  "description": "Fade Sorbet sig blocks in Ruby to reduce visual noise",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ruby",
    "sorbet",
    "types",
    "sig",
    "fade"
  ],
  "activationEvents": [
    "onLanguage:ruby"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sigfade.foldAllSigs",
        "title": "Sigfade: Fold All Sig Blocks"
      },
      {
        "command": "sigfade.unfoldAllSigs",
        "title": "Sigfade: Unfold All Sig Blocks"
      },
      {
        "command": "sigfade.toggleMode",
        "title": "Sigfade: Toggle Mode (Fade/Fold/Both)"
      }
    ],
    "configuration": {
      "title": "Sigfade",
      "properties": {
        "sigfade.mode": {
          "type": "string",
          "enum": [
            "fade",
            "fold",
            "both"
          ],
          "enumDescriptions": [
            "Fade sig blocks using reduced opacity",
            "Auto-fold sig blocks",
            "Both fade and allow folding"
          ],
          "default": "fade",
          "description": "How to handle Sorbet sig blocks"
        },
        "sigfade.opacity": {
          "type": "number",
          "default": 0.5,
          "minimum": 0.1,
          "maximum": 1.0,
          "description": "Opacity for faded sig blocks (0.1 = very faded, 1.0 = fully visible)"
        },
        "sigfade.autoFoldOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically fold all sig blocks when opening a Ruby file"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "esbuild": "^0.27.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
